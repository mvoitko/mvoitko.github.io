---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import CtaBanner from '../components/CtaBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const { title, description = 'Maksym Voitko — AI engineering leader and conference speaker building data platforms and multi-agent RAG systems.', activeNav = '' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' gc.zgo.at; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://mxvtk.goatcounter.com https://buttondown.com; form-action 'self' https://buttondown.com" />
    <meta name="description" content={description} />
    <meta name="author" content="Maksym Voitko" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="author" href="https://mxvtk.dev/about/" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl.href} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Maksym Voitko" />
    <meta property="og:image" content="https://mxvtk.dev/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://mxvtk.dev/og.png" />
    <!-- Feeds -->
    <link rel="alternate" type="application/rss+xml" title="Maksym Voitko — Blog" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Fonts: self-hosted woff2 with preload -->
    <link rel="preload" href="/fonts/fira-code.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://mxvtk.dev/#website",
          "url": "https://mxvtk.dev",
          "name": "Maksym Voitko",
          "description": "Technology leader and staff engineer building data platforms and AI systems.",
          "publisher": { "@id": "https://mxvtk.dev/#person" }
        },
        {
          "@type": "Person",
          "@id": "https://mxvtk.dev/#person",
          "name": "Maksym Voitko",
          "url": "https://mxvtk.dev",
          "jobTitle": "R&D Tech Lead",
          "worksFor": {
            "@type": "Organization",
            "name": "Monday.com",
            "url": "https://monday.com"
          },
          "alumniOf": [
            {
              "@type": "EducationalOrganization",
              "name": "National Technical University of Ukraine \"Kyiv Polytechnic Institute\"",
              "url": "https://kpi.ua"
            },
            {
              "@type": "EducationalOrganization",
              "name": "Kyiv National University of Construction and Architecture",
              "url": "https://knuba.edu.ua"
            }
          ],
          "memberOf": [
            {
              "@type": "Organization",
              "name": "AI Accelerator Institute"
            },
            {
              "@type": "Organization",
              "name": "Lens Champions"
            }
          ],
          "knowsAbout": [
            "Retrieval-Augmented Generation (RAG)",
            "MLOps",
            "Data Platforms",
            "Computer Vision",
            "Machine Learning",
            "Kubernetes",
            "Python",
            "Go",
            "AI Engineering Leadership",
            "Data Engineering",
            "LangChain",
            "LlamaIndex",
            "FastAPI",
            "PyTorch"
          ],
          "sameAs": [
            "https://linkedin.com/in/mvoitko",
            "https://github.com/mvoitko",
            "https://stackoverflow.com/users/5592286/max-voitko",
            "https://x.com/mxvtk1",
            "https://www.threads.com/@m_voitko",
            "https://instagram.com/@m_voitko",
            "https://t.me/forgottendatashadows"
          ]
        }
      ]
    })} />
  </head>
  <body>
    <script is:inline>
      (function() {
        try {
          var theme = localStorage.getItem('theme');
          if (theme) document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
    <a class="skip-to-content" href="#main-content">Skip to content</a>
    <Header activeNav={activeNav} />
    <main id="main-content">
      <slot />
    </main>
    <NewsletterSignup />
    <CtaBanner />
    <Footer />
    <script>
      function initThemeToggle() {
        const toggle = document.querySelector('.theme-toggle') as HTMLButtonElement | null;
        if (!toggle) return;

        // Set initial aria-pressed based on current theme
        const initial = document.documentElement.getAttribute('data-theme');
        toggle.setAttribute('aria-pressed', initial === 'light' ? 'true' : 'false');

        toggle.addEventListener('click', () => {
          const html = document.documentElement;
          const current = html.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          toggle.setAttribute('aria-pressed', next === 'light' ? 'true' : 'false');

          // Rotate the icon
          const icon = toggle.querySelector('.icon-dark, .icon-light') as HTMLElement | null;
          const visible = next === 'light'
            ? toggle.querySelector('.icon-light') as HTMLElement | null
            : toggle.querySelector('.icon-dark') as HTMLElement | null;
          if (visible) {
            visible.style.transform = 'rotate(180deg)';
            setTimeout(() => { visible.style.transform = ''; }, 300);
          }

          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      }

      initThemeToggle();
      document.addEventListener('astro:after-swap', initThemeToggle);
    </script>
    <script is:inline>
      // Scroll reveal observer with staggered siblings
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        var revealDelay = 0;
        var lastBatch = 0;
        var observer = new IntersectionObserver(function(entries) {
          var now = Date.now();
          if (now - lastBatch > 300) revealDelay = 0;
          lastBatch = now;
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = revealDelay;
              el.style.transitionDelay = delay + 'ms';
              el.classList.add('revealed');
              revealDelay += 60;
              observer.unobserve(el);
            }
          });
        }, { threshold: 0.1 });
        document.querySelectorAll('[data-reveal]').forEach(function(el) { observer.observe(el); });
      }
    </script>
    <script data-goatcounter="https://mxvtk.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
  </body>
</html>
