---
import BentoCard from './BentoCard.astro';
---

<BentoCard span={8}>
  <div class="role-tag">head of data &amp; ai</div>
  <h3>About Me</h3>
  <p>10+ years building data and AI platforms — from QA automation to computer vision systems to multi-agent RAG pipelines. I love designing systems from scratch and leading teams that ship real products.</p>
</BentoCard>

<style>
  .role-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 6px;
    display: inline-block;
    margin-bottom: 1rem;
  }
</style>
