---
import BentoCard from './BentoCard.astro';
---

<BentoCard span={5}>
  <div class="card-header"><span class="card-icon">&#127793;</span><h3>Beyond Code</h3></div>
  <p class="beyond-text">Angel investor at <a href="https://badideas.fund" target="_blank" rel="noopener noreferrer" class="beyond-link">BADideas.fund</a> backing early-stage CEE/CIS startups. Lens Champion in the Kubernetes ecosystem. Member of the AI Accelerator Institute. Writing about AI and data engineering in Ukrainian.</p>
  <a class="telegram-link" href="https://t.me/forgottendatashadows" target="_blank" rel="noopener noreferrer"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg> Тіні Забутих Даних</a>
</BentoCard>

<style>
  .beyond-text {
    margin-bottom: 0.8rem;
  }
  .telegram-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    text-decoration: none;
    transition: opacity var(--transition);
    display: inline-block;
  }
  .telegram-link:hover { opacity: 0.8; }
  .beyond-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .beyond-link:hover { text-decoration-thickness: 2px; }
</style>
