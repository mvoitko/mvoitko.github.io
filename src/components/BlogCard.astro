---
interface Props {
  title: string;
  date: Date;
  description?: string;
  tags: string[];
  slug: string;
}
const { title, date, description, tags, slug } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<a href={`/blog/${slug}/`} class="blog-card" data-reveal>
  <div class="blog-card-date">{dateStr}</div>
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  {tags.length > 0 && (
    <div class="blog-card-tags">
      {tags.map(tag => <span class="blog-tag">{tag}</span>)}
    </div>
  )}
</a>

<style>
  .blog-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    transition: all var(--transition);
    margin-bottom: 1rem;
  }
  .blog-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--accent-border);
    transform: translateY(-2px);
  }
  .blog-card-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .blog-card h3 {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .blog-card p {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .blog-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-xs);
    background: var(--bg-subtle);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
</style>
