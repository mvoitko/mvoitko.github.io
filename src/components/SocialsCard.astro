---
import BentoCard from './BentoCard.astro';
import { displayLinks } from '../data/social-links';

const featured = displayLinks.filter(l => l.featured);
const compact = displayLinks.filter(l => !l.featured);
---

<BentoCard span={7} class="socials-card">
  <div class="card-header"><span class="card-icon">&#128279;</span><h3>Connect</h3></div>

  <div class="socials-bento">
    <div class="featured-row">
      {featured.map(link => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${link.name} — ${link.handle}`}
          class="social-tile featured"
        >
          <div class="tile-top">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={link.icon} />
            <span class="tile-name">{link.name}</span>
          </div>
          {link.description && <span class="tile-desc">{link.description}</span>}
        </a>
      ))}
    </div>

    <div class="compact-row">
      {compact.map(link => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${link.name} — ${link.handle}`}
          class="social-tile compact"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={link.icon} />
          <span class="tile-name">{link.name}</span>
        </a>
      ))}
    </div>
  </div>
</BentoCard>

<style>
  .socials-card {
    display: flex;
    flex-direction: column;
  }
  .socials-bento {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .featured-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-items: stretch;
    gap: 0.6rem;
  }
  .compact-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.6rem;
  }

  .social-tile {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: all var(--transition);
  }
  .social-tile:hover {
    border-color: var(--accent-border);
    background: var(--accent-dim);
    transform: translateY(-2px);
  }
  .social-tile:hover .tile-name {
    color: var(--accent);
    transition: color var(--transition);
  }

  /* Featured — vertical layout: icon+name top, description bottom */
  .social-tile.featured {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.1rem;
  }
  .tile-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tile-desc {
    font-size: var(--text-xs);
    opacity: 0.5;
  }

  /* Compact — inline icon + name */
  .social-tile.compact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
  }

  .tile-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .social-tile.compact .tile-name {
    font-size: var(--text-xs);
  }

  @media (max-width: 768px) {
    .compact-row {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 480px) {
    .featured-row {
      grid-template-columns: 1fr;
    }
    .compact-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
