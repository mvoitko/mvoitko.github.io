---
---

<section class="section-banner">
  <div class="section-banner-inner">
    <div class="section-banner-content">
      <div class="section-banner-prefix">&gt; newsletter.subscribe()</div>
      <h2>Stay in the <span class="highlight">loop.</span></h2>
      <p>I write about AI in production, MLOps under constraints, and what it actually takes to ship ML systems. No spam, unsubscribe anytime.</p>
    </div>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/mxvtk"
      method="post"
      class="newsletter-form"
    >
      <input type="email" name="email" placeholder="your@email.com" required />
      <button type="submit" class="btn btn-primary">subscribe &rarr;</button>
    </form>
  </div>
</section>

<style>
  .newsletter-form {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .newsletter-form input {
    width: 280px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color var(--transition);
  }
  .newsletter-form input:focus {
    border-color: var(--accent);
  }
  .newsletter-form input::placeholder {
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .newsletter-form {
      width: 100%;
    }
    .newsletter-form input {
      width: 100%;
    }
  }
</style>
