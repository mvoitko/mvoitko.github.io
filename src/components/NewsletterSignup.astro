---
---

<section class="newsletter-section" data-reveal>
  <div class="newsletter-icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
      <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/>
      <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/>
    </svg>
  </div>
  <h2>Stay in the <span class="highlight">loop.</span></h2>
  <p class="newsletter-desc">Occasional deep dives on shipping AI to production &mdash; RAG architectures, MLOps patterns, and lessons from building data teams. One email per month at most.</p>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/mxvtk"
    method="post"
    class="newsletter-form"
  >
    <label for="newsletter-email" class="sr-only">Email address</label>
    <div class="form-row">
      <input type="email" name="email" id="newsletter-email" placeholder="your@email.com" required />
      <button type="submit" class="btn btn-primary">subscribe <span class="arrow">&rarr;</span></button>
    </div>
    <p class="form-note">No spam, unsubscribe anytime.</p>
    <p class="form-status" aria-live="polite"></p>
  </form>
</section>

<style>
  .newsletter-section {
    width: 100%;
    padding: 5rem clamp(1.5rem, 5vw, 6rem) 4rem;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .newsletter-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    background: var(--accent-dim);
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-sm);
    color: var(--accent);
  }

  .newsletter-section h2 {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .newsletter-desc {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 2rem;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .form-row {
    display: flex;
    max-width: 450px;
    width: 100%;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color var(--transition);
  }
  .form-row:focus-within {
    border-color: var(--accent);
  }

  .newsletter-form input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    color: var(--text);
    border: none;
    outline: none;
  }
  .newsletter-form input::placeholder {
    color: var(--text-muted);
  }

  .newsletter-form .btn {
    border-radius: 0;
    flex-shrink: 0;
    border: none;
  }

  .form-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .form-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    min-height: 1.2em;
  }
  .form-status.success {
    color: var(--accent);
  }
  .form-status.error {
    color: var(--error);
  }

  @media (max-width: 480px) {
    .newsletter-section {
      padding: 3rem clamp(1.5rem, 5vw, 6rem) 2.5rem;
    }
    .form-row {
      flex-direction: column;
      border-radius: var(--radius-sm);
    }
    .newsletter-form input {
      border-bottom: 1px solid var(--border);
    }
    .newsletter-form .btn {
      border-radius: 0 0 var(--radius-sm) var(--radius-sm);
      width: 100%;
    }
  }
</style>

<script>
  function initNewsletter() {
    const form = document.querySelector('.newsletter-form') as HTMLFormElement | null;
    if (!form || form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const status = form.querySelector('.form-status');
      const email = form.querySelector('input[type="email"]');
      if (!btn || !status || !email) return;

      // Client-side validation before submit
      const emailInput = email as HTMLInputElement;
      if (!emailInput.value.trim()) {
        status.textContent = '> enter your email address.';
        status.className = 'form-status error';
        emailInput.focus();
        return;
      }
      if (!emailInput.validity.valid) {
        status.textContent = '> invalid email format.';
        status.className = 'form-status error';
        emailInput.focus();
        return;
      }

      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = 'sending...';
      status.textContent = '';
      status.className = 'form-status';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as any)
        });

        if (res.ok || res.status === 303 || res.type === 'opaque') {
          status.textContent = '> subscribed. check your inbox.';
          status.classList.add('success');
          (email as HTMLInputElement).value = '';
        } else {
          status.textContent = '> something went wrong. try again.';
          status.classList.add('error');
        }
      } catch {
        status.textContent = '> connection failed. try again.';
        status.classList.add('error');
      }

      (btn as HTMLButtonElement).disabled = false;
      btn.textContent = '';
      btn.append('subscribe ');
      const arrow = document.createElement('span');
      arrow.className = 'arrow';
      arrow.textContent = '\u2192';
      btn.appendChild(arrow);
    });
  }

  initNewsletter();
  document.addEventListener('astro:after-swap', initNewsletter);
</script>
