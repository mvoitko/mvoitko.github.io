---

<div class="bento-card span-4 stats-card">
  <div class="stat">
    <div class="stat-number" data-count="10">10+</div>
    <div class="stat-label">years in tech</div>
  </div>
  <div class="stat">
    <div class="stat-number" data-count="15">15+</div>
    <div class="stat-label">engineers led</div>
  </div>
</div>

<style>
  .stats-card {
    display: flex;
    flex-direction: row;
    justify-content: space-evenly;
    align-items: center;
    text-align: center;
  }
  .stat-number {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
</style>

<script>
  function initStatsAnimation() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const card = document.querySelector('.stats-card');
    if (!card) return;
    const observer = new IntersectionObserver(([entry]) => {
      if (!entry.isIntersecting) return;
      observer.disconnect();
      card.querySelectorAll('[data-count]').forEach(el => {
        const target = parseInt(el.dataset.count, 10);
        if (!Number.isFinite(target) || target <= 0) return;
        const duration = 2000;
        const start = performance.now();
        el.textContent = '0+';
        function step(now) {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 4);
          el.textContent = Math.round(target * ease) + '+';
          if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
    }, { threshold: 0.5 });
    observer.observe(card);
  }

  initStatsAnimation();
  document.addEventListener('astro:after-swap', initStatsAnimation);
</script>
