---

<div class="bento-card span-4 stats-card">
  <div class="stat-line">
    <span class="stat-value" data-count="10">10+</span>
    <span class="stat-desc">years shipping production systems</span>
  </div>
  <div class="stat-line">
    <span class="stat-value" data-count="15">15+</span>
    <span class="stat-desc">engineers hired, mentored &amp; led</span>
  </div>
</div>

<style>
  .stats-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
  }
  .stat-line {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .stat-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>

<script>
  function initStatsAnimation() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const card = document.querySelector('.stats-card');
    if (!card) return;
    const observer = new IntersectionObserver(([entry]) => {
      if (!entry.isIntersecting) return;
      observer.disconnect();
      card.querySelectorAll('.stat-value[data-count]').forEach(el => {
        const target = parseInt(el.dataset.count, 10);
        if (!Number.isFinite(target) || target <= 0) return;
        const duration = 2000;
        const start = performance.now();
        el.textContent = '0+';
        function step(now) {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 4);
          el.textContent = Math.round(target * ease) + '+';
          if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
    }, { threshold: 0.5 });
    observer.observe(card);
  }

  initStatsAnimation();
  document.addEventListener('astro:after-swap', initStatsAnimation);
</script>
