---
import BentoCard from './BentoCard.astro';
import SkillPill from './SkillPill.astro';

const skills = ['Python', 'Go', 'AWS', 'GCP', 'Kubernetes', 'PyTorch', 'LangChain', 'Kafka', 'Airflow', 'FastAPI', 'Docker', 'Terraform', 'ArgoCD'];
---

<BentoCard span={5}>
  <div class="card-header"><span class="card-icon">&#9881;</span><h3>Tech Stack</h3></div>
  <p>The tools I reach for most often.</p>
  <ul class="skills-grid" role="list">
    {skills.map(skill => <li><SkillPill name={skill} /></li>)}
  </ul>
</BentoCard>
