---
---

<section class="hero">
  <canvas id="entropy-canvas" aria-hidden="true"></canvas>
  <div class="hero-content">
    <div class="hero-prefix">hello, world<span class="cursor"></span></div>
    <h1>Maksym <span class="highlight">Voitko</span></h1>
    <p class="hero-subtitle">
      I design AI systems that survive production, build teams that multiply talent, and write about the messy middle where engineering meets reality. R&amp;D Tech Lead at <a href="https://monday.com" target="_blank" rel="noopener noreferrer" class="monday-link">Monday.com</a>.
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="/speaking/">invite me to speak <span class="arrow">&rarr;</span></a>
      <a class="btn btn-outline" href="/blog/">read my blog <span class="arrow">&rarr;</span></a>
      <a class="btn btn-ghost" href="/timeline/">view my journey</a>
    </div>
    <a href="#at-a-glance" class="scroll-hint" aria-label="Scroll to content">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: var(--header-height, 64px);
  }
  #entropy-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  @media (hover: hover) {
    .hero { cursor: crosshair; }
  }
  .hero-prefix {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero-prefix::before {
    content: '>';
    opacity: 0.5;
  }
  .cursor {
    display: inline-block;
    width: 8px;
    height: 1.1em;
    background: var(--accent);
    animation: blink 1s step-end infinite;
    vertical-align: text-bottom;
    margin-left: 2px;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
  .hero h1 {
    font-family: var(--font-mono);
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  .hero-subtitle {
    font-size: var(--text-xl);
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }
  .hero-subtitle strong { color: var(--text); }
  .monday-link {
    color: var(--text);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: color var(--transition);
  }
  .monday-link:hover { color: var(--accent); text-decoration-thickness: 2px; }
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .scroll-hint {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 2rem;
    color: var(--text-muted);
    transition: color var(--transition);
  }
  .scroll-hint:hover {
    color: var(--accent);
  }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-hint svg {
      animation: bounce 2s infinite;
    }
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  @media (max-width: 768px) {
    .hero { min-height: calc(100dvh - 2rem); padding-top: calc(var(--header-height, 64px) + 1rem); }
    .hero-subtitle { font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; }
    .hero-ctas { flex-direction: column; gap: 0.75rem; }
    .hero-ctas a { text-align: center; }
  }
</style>

<script>
  let cleanup: (() => void) | null = null;

  function initEntropy() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (cleanup) { cleanup(); cleanup = null; }

    const canvas = document.getElementById('entropy-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const hero = canvas.closest('.hero') as HTMLElement;
    if (!hero) return;

    const accentHex = getComputedStyle(document.documentElement)
      .getPropertyValue('--accent').trim() || '#00E87E';
    const ar = parseInt(accentHex.slice(1, 3), 16);
    const ag = parseInt(accentHex.slice(3, 5), 16);
    const ab = parseInt(accentHex.slice(5, 7), 16);

    let W = 0, H = 0, MID = 0;
    const dpr = Math.min(devicePixelRatio || 1, 2);
    let ordered: {
      x: number; y: number; homeX: number; homeY: number;
      vx: number; vy: number; torn: number; healDelay: number;
      neighbors: any[];
    }[] = [];
    let chaotic: { x: number; y: number; vx: number; vy: number }[] = [];
    let all: { x: number; y: number }[] = [];
    let surges: { x: number; y: number; radius: number; strength: number; speed: number; life: number }[] = [];
    const CONNECT = 50;
    const MOUSE_R = 120;
    let mx = -1, my = -1;
    let surgeTimer = 0, nextSurge = 40;
    let rafId = 0;

    const CELL = CONNECT;
    let grid: Record<string, { x: number; y: number }[]> = {};

    function buildGrid() {
      grid = {};
      for (let i = 0; i < all.length; i++) {
        const p = all[i];
        const key = (p.x / CELL | 0) + '|' + (p.y / CELL | 0);
        (grid[key] || (grid[key] = [])).push(p);
      }
    }

    function resize() {
      const rect = hero.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      MID = W / 2;
      initParticles();
      surges.length = 0;
      surgeTimer = 0;
    }

    function initParticles() {
      ordered = [];
      chaotic = [];
      const spacing = W < 768 ? 40 : 32;

      const cols = Math.floor(MID / spacing);
      const rows = Math.floor(H / spacing);
      const offX = (MID - (cols - 1) * spacing) / 2;
      const offY = (H - (rows - 1) * spacing) / 2;

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const hx = offX + c * spacing;
          const hy = offY + r * spacing;
          ordered.push({
            x: hx, y: hy, homeX: hx, homeY: hy,
            vx: 0, vy: 0, torn: 0, healDelay: 0,
            neighbors: []
          });
        }
      }

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const idx = r * cols + c;
          const nbrs: typeof ordered = [];
          for (let dr = -1; dr <= 1; dr++) {
            for (let dc = -1; dc <= 1; dc++) {
              if (dr === 0 && dc === 0) continue;
              const nr = r + dr, nc = c + dc;
              if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
                nbrs.push(ordered[nr * cols + nc]);
              }
            }
          }
          ordered[idx].neighbors = nbrs;
        }
      }

      const count = ordered.length;
      for (let i = 0; i < count; i++) {
        chaotic.push({
          x: MID + Math.random() * MID,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 2,
          vy: (Math.random() - 0.5) * 2
        });
      }

      all = (ordered as { x: number; y: number }[]).concat(chaotic);
    }

    function spawnSurge() {
      const roll = Math.random();
      let radius: number, strength: number, speed: number;
      if (roll < 0.15) {
        radius = 100 + Math.random() * 80;
        strength = 0.8 + Math.random() * 0.2;
        speed = 1.5 + Math.random() * 1.5;
      } else if (roll < 0.45) {
        radius = 55 + Math.random() * 45;
        strength = 0.5 + Math.random() * 0.3;
        speed = 1 + Math.random() * 1;
      } else {
        radius = 25 + Math.random() * 30;
        strength = 0.3 + Math.random() * 0.3;
        speed = 0.6 + Math.random() * 0.8;
      }
      surges.push({ x: MID + 10, y: Math.random() * H, radius, strength, speed, life: 1.0 });
    }

    function drawConn(a: { x: number; y: number }, b: { x: number; y: number }) {
      const dx = a.x - b.x, dy = a.y - b.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < CONNECT) {
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = 'rgba(' + ar + ',' + ag + ',' + ab + ',' + ((1 - dist / CONNECT) * 0.15) + ')';
        ctx.stroke();
      }
    }

    function tick() {
      if (document.hidden) { rafId = requestAnimationFrame(tick); return; }
      ctx.clearRect(0, 0, W, H);

      // Surges
      surgeTimer++;
      if (surgeTimer >= nextSurge) {
        surgeTimer = 0;
        spawnSurge();
        nextSurge = Math.random() < 0.3 ? 15 + Math.random() * 25 : 50 + Math.random() * 80;
      }

      for (let s = surges.length - 1; s >= 0; s--) {
        const sg = surges[s];
        sg.x -= sg.speed;
        sg.life *= 0.985;
        if (sg.life < 0.02 || sg.x < -sg.radius) { surges.splice(s, 1); continue; }
        for (let i = 0; i < ordered.length; i++) {
          const o = ordered[i];
          const dx = o.homeX - sg.x, dy = o.homeY - sg.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < sg.radius) {
            const force = (1 - dist / sg.radius) * sg.strength * sg.life;
            o.vx += (2 + Math.random() * 3) * force;
            o.vy += (Math.random() - 0.5) * 4 * force;
            o.torn = Math.min(1, o.torn + force * 0.4);
            o.healDelay = Math.max(o.healDelay, 40 + (force * 80 | 0));
          }
        }
      }

      // Update chaotic particles
      for (let i = 0; i < chaotic.length; i++) {
        const c = chaotic[i];
        c.vx += (Math.random() - 0.5) * 0.6;
        c.vy += (Math.random() - 0.5) * 0.6;
        c.vx *= 0.94;
        c.vy *= 0.94;
        c.x += c.vx;
        c.y += c.vy;
        if (c.x < MID * 0.7) c.vx += 0.3;
        if (c.x > W) { c.x = W; c.vx *= -0.8; }
        if (c.y < 0) { c.y = 0; c.vy *= -1; }
        if (c.y > H) { c.y = H; c.vy *= -1; }
        if (mx >= 0) {
          const dx = c.x - mx, dy = c.y - my;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MOUSE_R && dist > 1) {
            const f = (1 - dist / MOUSE_R) * 0.8;
            c.vx += dx / dist * f;
            c.vy += dy / dist * f;
          }
        }
      }

      // Pre-filter chaotic particles near boundary for influence checks
      const boundaryChaotic: typeof chaotic = [];
      for (let i = 0; i < chaotic.length; i++) {
        if (chaotic[i].x < MID + 80) boundaryChaotic.push(chaotic[i]);
      }

      // Update ordered particles
      for (let i = 0; i < ordered.length; i++) {
        const o = ordered[i];

        // Boundary influence from nearby chaotic particles
        if (o.homeX > MID - 80) {
          for (let j = 0; j < boundaryChaotic.length; j++) {
            const c = boundaryChaotic[j];
            const dx = o.x - c.x, dy = o.y - c.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 60) {
              const str = (1 - dist / 60) * 0.04;
              o.vx += c.vx * str;
              o.vy += c.vy * str;
              o.torn = Math.min(1, o.torn + str * 0.3);
              o.healDelay = Math.max(o.healDelay, 20);
            }
          }
        }

        // Cursor disruption
        if (mx >= 0) {
          const dx = o.x - mx, dy = o.y - my;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MOUSE_R) {
            const s = 1 - dist / MOUSE_R;
            o.torn = Math.min(1, o.torn + s * 0.06);
            o.vx += (Math.random() - 0.5) * s * 2;
            o.vy += (Math.random() - 0.5) * s * 2;
            o.healDelay = Math.max(o.healDelay, 30);
          }
        }

        // Cascade via precomputed grid neighbors
        if (o.torn > 0.5) {
          const nbrs = o.neighbors;
          for (let k = 0; k < nbrs.length; k++) {
            const n = nbrs[k];
            if (n.torn >= o.torn - 0.2) continue;
            const dx = o.x - n.x, dy = o.y - n.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 35) {
              const spread = (1 - dist / 35) * o.torn * 0.02;
              n.torn = Math.min(1, n.torn + spread);
              n.vx += o.vx * spread * 0.5;
              n.vy += o.vy * spread * 0.5;
              n.healDelay = Math.max(n.healDelay, 15);
            }
          }
        }

        // Healing
        if (o.healDelay > 0) {
          o.healDelay--;
        } else {
          o.torn *= 0.985;
          const spring = 0.025 + 0.035 * (1 - o.torn);
          o.vx += (o.homeX - o.x) * spring;
          o.vy += (o.homeY - o.y) * spring;
        }
        o.vx += (o.homeX - o.x) * 0.003;
        o.vy += (o.homeY - o.y) * 0.003;
        o.vx *= 0.93;
        o.vy *= 0.93;
        o.x += o.vx;
        o.y += o.vy;
      }

      // Spatial grid for connection drawing
      buildGrid();

      ctx.lineWidth = 0.5;
      for (const key in grid) {
        const cell = grid[key];
        const sep = key.indexOf('|');
        const cx = parseInt(key.substring(0, sep));
        const cy = parseInt(key.substring(sep + 1));

        for (let i = 0; i < cell.length; i++) {
          for (let j = i + 1; j < cell.length; j++) {
            drawConn(cell[i], cell[j]);
          }
        }

        const adj0 = grid[(cx + 1) + '|' + cy];
        const adj1 = grid[cx + '|' + (cy + 1)];
        const adj2 = grid[(cx + 1) + '|' + (cy + 1)];
        const adj3 = grid[(cx - 1) + '|' + (cy + 1)];
        const adjs = [adj0, adj1, adj2, adj3];
        for (let a = 0; a < 4; a++) {
          const adj = adjs[a];
          if (!adj) continue;
          for (let i = 0; i < cell.length; i++) {
            for (let j = 0; j < adj.length; j++) {
              drawConn(cell[i], adj[j]);
            }
          }
        }
      }

      // Draw ordered particles
      for (let i = 0; i < ordered.length; i++) {
        const o = ordered[i];
        const alpha = 0.4 + o.torn * 0.5;
        const rad = 1.3 + o.torn * 1.2;
        const pr = ar + (220 - ar) * o.torn * 0.5 | 0;
        const pg = ag + (255 - ag) * o.torn * 0.1 | 0;
        const pb = ab + (220 - ab) * o.torn * 0.4 | 0;
        ctx.beginPath();
        ctx.arc(o.x, o.y, rad, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + pr + ',' + pg + ',' + pb + ',' + alpha + ')';
        ctx.fill();
      }

      // Draw chaotic particles
      for (let i = 0; i < chaotic.length; i++) {
        ctx.beginPath();
        ctx.arc(chaotic[i].x, chaotic[i].y, 1.8, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + ar + ',' + ag + ',' + ab + ',0.7)';
        ctx.fill();
      }

      rafId = requestAnimationFrame(tick);
    }

    function onMove(e: MouseEvent) {
      const rect = hero.getBoundingClientRect();
      mx = e.clientX - rect.left;
      my = e.clientY - rect.top;
    }
    function onLeave() { mx = -1; my = -1; }
    function onTouch(e: TouchEvent) {
      const rect = hero.getBoundingClientRect();
      mx = e.touches[0].clientX - rect.left;
      my = e.touches[0].clientY - rect.top;
    }

    hero.addEventListener('mousemove', onMove);
    hero.addEventListener('mouseleave', onLeave);
    hero.addEventListener('touchmove', onTouch, { passive: true });
    hero.addEventListener('touchend', onLeave, { passive: true });

    const ro = new ResizeObserver(resize);
    ro.observe(hero);
    resize();
    rafId = requestAnimationFrame(tick);

    cleanup = () => {
      cancelAnimationFrame(rafId);
      ro.disconnect();
      hero.removeEventListener('mousemove', onMove);
      hero.removeEventListener('mouseleave', onLeave);
      hero.removeEventListener('touchmove', onTouch);
      hero.removeEventListener('touchend', onLeave);
    };
  }

  initEntropy();
  document.addEventListener('astro:after-swap', initEntropy);
  document.addEventListener('astro:before-swap', () => {
    if (cleanup) { cleanup(); cleanup = null; }
  });
</script>
