---
interface Props {
  activeNav?: string;
}
const { activeNav = '' } = Astro.props;
const navItems = [
  { name: 'home', href: '/' },
  { name: 'about', href: '/about/' },
  { name: 'blog', href: '/blog/' },
  { name: 'speaking', href: '/speaking/' },
  { name: 'resume', href: '/cv/' },
  { name: 'timeline', href: '/timeline/' },
];
---

<header>
  <a class="logo" href="/">mv<span>.</span>dev</a>
  <nav aria-label="Main navigation">
    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-links" aria-label="Menu">
      <svg class="hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line class="line-top" x1="3" y1="6" x2="21" y2="6" />
        <line class="line-mid" x1="3" y1="12" x2="21" y2="12" />
        <line class="line-bot" x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
    <div class="nav-links" id="nav-links">
      {navItems.map(item => (
        <a
          href={item.href}
          class={activeNav === item.name ? 'active' : ''}
          {...(activeNav === item.name ? { 'aria-current': 'page' } : {})}
        >
          {item.name}
        </a>
      ))}
    </div>
    <button class="theme-toggle" aria-label="Toggle theme" aria-pressed="false" title="Toggle theme">
      <span class="icon-dark">[dark]</span>
      <span class="icon-light">[light]</span>
    </button>
  </nav>
</header>

<style>
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: var(--z-header);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 calc(max(0px, (100vw - 1440px) / 2) + clamp(1.5rem, 5vw, 6rem));
    height: var(--header-height, 64px);
    border-bottom: 1px solid var(--border);
  }
  header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--header-bg, rgba(10, 14, 20, 0.8));
    backdrop-filter: blur(20px);
    z-index: -1;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .logo span { color: var(--text-muted); }

  nav { display: flex; gap: 2rem; align-items: center; }

  .nav-links { display: flex; gap: 2rem; align-items: center; }

  nav a {
    position: relative;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
    letter-spacing: 0.02em;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  nav a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }
  nav a:hover::after { transform: scaleX(1); opacity: 0.5; }
  nav a.active::after { transform: scaleX(1); }
  nav a:hover, nav a.active { color: var(--accent); }
  nav a:focus-visible { outline: 2px solid var(--accent); outline-offset: 4px; }

  /* ── Nav toggle (mobile hamburger) ── */
  .nav-toggle {
    display: none;
    width: 44px; height: 44px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0;
    align-items: center;
    justify-content: center;
  }
  .nav-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav-toggle .hamburger-icon line {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  .nav-toggle[aria-expanded="true"] .line-top {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .line-mid {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .line-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Theme toggle ── */
  .theme-toggle {
    width: auto; height: 36px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    transition: all var(--transition);
    padding: 0 0.5rem;
  }
  .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }
  .theme-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .theme-toggle .icon-dark,
  .theme-toggle .icon-light {
    display: inline-block;
    transition: transform 0.3s ease;
  }
  .icon-light { display: none; }
  :global([data-theme="light"]) .icon-dark { display: none; }
  :global([data-theme="light"]) .icon-light { display: inline-block; }

  /* ── Mobile styles ── */
  @media (max-width: 768px) {
    header { padding: 0 1.5rem; }
    .logo { font-size: 0.95rem; }

    .nav-toggle { display: flex; }

    .nav-links {
      display: none;
      position: fixed;
      inset: 0;
      height: 100dvh;
      padding-top: 5rem;
      background: var(--bg);
      z-index: var(--z-mobile-nav);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }
    .nav-links.nav-open {
      display: flex;
    }

    .nav-links a {
      font-size: var(--text-xl);
      letter-spacing: 0;
    }
  }
</style>

<script>
  function initHamburger() {
    const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
    const navLinks = document.getElementById('nav-links');
    if (!toggle || !navLinks) return;

    function openMenu() {
      navLinks!.classList.add('nav-open');
      toggle!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      navLinks!.classList.remove('nav-open');
      toggle!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navLinks.classList.contains('nav-open')) {
        closeMenu();
        toggle.focus();
      }
    });
  }

  initHamburger();
  document.addEventListener('astro:after-swap', initHamburger);
</script>
