---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Maksym Voitko" description="Technology leader and staff engineer building data platforms and AI systems." activeNav="about">
  <div class="about-page">
    <article class="prose" aria-label="About Maksym Voitko">
      <h1 class="page-title">About <span class="highlight">Me</span></h1>
      <p>
        Hi, I'm <strong>Maksym Voitko</strong> — a technology leader and staff-level engineer with over ten years of experience building data and AI platforms. I am joining <a href="https://monday.com" target="_blank" rel="noopener noreferrer">Monday.com</a> as an R&D Tech Lead (starting 13 April 2026).
      </p>
      <p>
        My career has evolved from quality assurance to leading research and development in AI.
      </p>
      <p>
        Beyond engineering, I am a <strong>Lens champion</strong> and a member of the <strong>AI Accelerator Institute</strong>. I enjoy reading science fiction and fantasy, mentoring up-and-coming engineers, and sharing knowledge through my Ukrainian-language Telegram channel.
      </p>
    </article>
  </div>
</BaseLayout>

<style>
  .about-page {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 64px;
  }

  .prose {
    max-width: 700px;
  }
  .prose h1 {
    margin-bottom: 2rem;
  }
  .prose p {
    font-size: 1.05rem;
    color: var(--text);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: text-decoration-thickness 0.2s;
  }
  .prose a:hover { text-decoration-thickness: 2px; }

  @media (max-width: 768px) {
    .about-page { padding: 64px 0 2rem; min-height: auto; }
  }
</style>
